# ========================================
# CredResolve DCO Agent — Environment Config
# ========================================

# LLM Provider — Google Gemini (free tier)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Voice AI
SARVAM_API_KEY=your-sarvam-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=hindi-female-voice-id

# Database
DATABASE_URL=sqlite:///./credsolve.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Monitoring
PROMETHEUS_PORT=9090

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Agent Config
AGENT_NAME=Arya
AGENT_COMPANY=CredResolve
DEFAULT_LANGUAGE=hi
